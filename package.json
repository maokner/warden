{
  "name": "@maokner/warden",
  "version": "0.1.0",
  "description": "A local guardrail for OpenAI Agents SDK apps — classify, approve, and audit every tool call.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./openai": {
      "types": "./dist/src/adapters/openai.d.ts",
      "import": "./dist/src/adapters/openai.js"
    }
  },
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist/src",
    "docs",
    "examples",
    "README.md"
  ],
  "bin": {
    "warden": "./dist/src/cli/index.js"
  },
  "scripts": {
    "prebuild": "node scripts/clean-dist.mjs",
    "build": "tsc -p tsconfig.json",
    "test": "pnpm run build && node --test \"dist/tests/**/*.test.js\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  }
}
